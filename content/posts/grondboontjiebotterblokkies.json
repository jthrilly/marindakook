  "directionsTitle": "Metode",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Sit bakpapier in ‘n bak en spuit met Spray and Cook",
     "Smelt die grondboontjiebotter, sjokolade en botter in ‘n pot op die stoof of in die mikrogolf. Laat dit effens afkoel. Roer met ‘n houtlepel gereeld.",
     "Roer die marshmellows by die grondboontjiemengsel.",
     "Krap die mengsel uit op die bakpapier en maak glad.  Sprinkel die orige marshmellows en Chuckels oor.  Druk dit effens vas.",
     "Sit dit in die yskas oornag of vir ten minste 2 uur.",
     "Sny dit in blokke."
    ]
   }
