  "ingredientGroups": [
   {
    "title": null,
    "items": [
     "500g beesmaalvleis",
     "1 x 690 g bottel gekoopte tamatie- pastasous van jou keuse",
     "750 ml gaarrys ( 3 koppies)",
     "750 ml gaar pampoen fyn gedruk",
     "20 ml olie",
     "1 ui fyngekap",
     "20 ml botter",
     "2,5 ml fyn kaneel",
     "sout en peper"
    ]
   }
  ],
  "directionsTitle": "Metode",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Stel die oond op 180C en smeer &#8216;n vierkantige oondbak.",
     "Braai die ui liggies in die olie.  Voeg jou maalvleis by en braai tot dit begin kleur kry.",
     "Gooi die pastasous by die vleis en kook vir 10-15 minute tot dit alles begin dik word.  Sout en peper na smaak Hou dit eenkant tot jy dit nodig kry.",
     "Terwyl die pampoen warm is, roer die kaneel, botter en sout en peper by.",
     "Plaas jou rys onder in die oondbak.",
     "Skep die pampoen op die ry.",
     "Skep die maalvleis op die pampoen.",
     "Bak in die oond vir 25 minute."
    ]
   }
