  "ingredientGroups": [
   {
    "title": null,
    "items": [
     "10 ml gis",
     "5 ml suiker",
     "60 ml louwater",
     "250 ml x 4 koekmeel ( 4 koppies)",
     "knippie sout",
     "185 ml griekse jogurt",
     "30 ml olie",
     "180 ml loumelk"
    ]
   }
  ],
  "directionsTitle": "Metode",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Meng die gis, suiker en 60 ml louwater in &#8216;n beker.  Los dit vir 10 min tot dit begin gis. (borrels maak)",
     "In &#8216;n mengbak roer die meel en sout saam.",
     "Maak &#8216;n holte in die meel en meng die gismengsel met &#8216;n houtlepel in.",
     "Roer nou die jogurt, olie en melk in die meel. Roer tot alles mooi bymekaar kom.",
     "Strooi meel op &#8216;n oppervlak en knie die deeg vir 5 minute tot alles mooi bymekaar kom.  Sit die deeg in &#8216;n bak en maak dit toe met gladwrap.  Los dit op &#8216;n warm plek tot dit verdubbel het.",
     "Verdeel die deeg in 12 porsies.  Rol klein balletjies en rol elke balletjie in &#8216;n sirkel.",
     "In &#8216;n warm pan wat klein bietjie olie in het, braai die naan vir 1 tot 2 minute aan &#8216;n kant.",
     "Soos die naan uit die pan kom, smeer dit met gesmelte botter.",
     "As jy wil, kan jy fyngekapte knoffel saam met die botter smelt en knoffelbotter smeer oor die naan.  Ek het danja by my botter geroer."
    ]
   }
