    "items": [
     "8 hoenderdye",
     "1 rooi ui in ringe gesny",
     "1 tamatie in ringe gesny",
     "Olyfolie",
     "Sout",
     "Peper",
     "500 ml Spekko Basmati-rys (was en dreineer dit)",
     "2 knoffelhuisies fyn gerasper",
     "4 x 250 ml kookwater",
     "5 ml paprika",
     "15 ml Baharat (koop by Woolies)",
     "30 ml dadelstroop of heuning (koop dadelstroop ook by Woolies)",
     "50 ml tamatiepaste",
     "Gekapte pietersielie vir afronding"
    ]
   }
  ],
  "directionsTitle": "Metode",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Stel die oond op 180C",
     "Gooi 10 ml growwe sout op die bodem van jou pan.",
     "Bedruip die pan met ‘n dun lagie olyfolie.",
     "Pak die gesnyde rooiui en tamatie op die olyfolie.",
     "Skep die gedreineerde rys op die laag tamatieskywe en uie.",
     "Pak die hoender op die rys. Sout en peper na smaak.",
     "Nou jou sous: meng die paprika, Baharat,dadelstroop, tamatiepaste, fyn knoffel en 125 ml olyfolie saam – dit ruik heerlik.",
     "Roer nou jou kookwater by en meng goed. Skep lepels voel oor die hoender.",
     "Nou: maak bakpapier nat en maak die hoender toe met die nat bakpapier. Maak dan toe met tinfoelie sodat dit lekker kan stoom.",
     "Na 90 min maak jy oop en laat die hoender verbruin in die oond.",
     "Rond af met gekapte pietersielie.",
     "Dieplekker!!!!!!!!!!"
    ]
   }
