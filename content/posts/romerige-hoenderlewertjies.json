     "1 ui fyngekap",
     "15 ml olie",
     "10 ml gerookte paprika",
     "5 ml fyn komyn",
     "10 ml rissievlokkies of 2 rissies fyngekap",
     "125 ml hoenderaftreksel (los 1 blokkie op im 125 ml kookwater)",
     "10 ml tamatiepaste",
     "5ml suurlemoensap",
