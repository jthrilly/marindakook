  "ingredientsTitle": "Bestanddele",
  "ingredientGroups": [
   {
    "title": null,
    "items": [
     "¾ koppie Spekko langkorrel stoombehandelde (“parboiled”) rys",
     "3 koppies water",
     "2ml sout",
     "1 x blik heelpitmielies",
     "½ koppie gerasperde chedderkaas",
     "2 eiers"
    ]
   },
   {
    "title": "Vir die bolaag",
    "items": [
     "½ koppie crème fraîche",
     "1 suurlemoen",
     "sout",
     "gemaalde swartpeper",
     "2 sprietuie",
     "1 avokado",
     "5ml rissievlokkies",
     "vars koljander"
    ]
   }
  ],
  "directionsTitle": "Metode",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Bring die water, sout en Spekko-rys tot kookpunt in ‘n pan",
     "Verlaag die hitte tot medium en kook vir 20-25 minute",
     "Gooi die rys in ‘n sif om die oortollige water te dreineer",
     "Hou dit eenkant om af te koel",
     "Dreineer die heelpitmielies en droog dit met kombuispapier of ‘n skoon lap",
     "Meng die rys en gerasperde kaas met ¾ van die heelpitmielies in ‘n mengbak (hou die res vir die opskepslag)",
     "Klits die eiers en meng dit dan goed deur die rysmengsel",
     "Verhit ‘n wafelpan en bespuit dit met ‘n kossproeimiddel (“Spray &amp; Cook”)",
     "Gooi ‘n lepelvol van die mengsel in die voorafverhitte wafelpan, maak die deksel toe, en maak dit gaar tot goudbruin",
     "Maak wafels met die volle beslag",
     "Terwyl die wafels gaargemaak word, kan daar begin word met die voorbereiding van die bolaag",
     "Meng die crème fraîche, met fyn gerasperde suurlemoenskil (“zest”) en ‘n knippie sout en peper",
     "Sny die sprietuie in dun snytjies",
     "Sny die avokado in dun snye en druk suurlemoensap bo-oor",
     "Plaas die wafels op ‘n opdienbord en plaas bo-op elke wafel ‘n paar snye avokado en ‘n lepel crème fraîche",
     "Sprinkel dan die sprietuie en die orige heelpitmielies oor",
     "Garneer met rissievlokkies en vars koljander"
    ]
   }
  ],
