  "ingredientsTitle": "Bestanddele",
  "ingredientGroups": [
   {
    "title": null,
    "items": [
     "25 ml olie",
     "1 ui, in klein stukkies gekap",
     "750g – 1kg goeie maalvleis",
     "3 snye brood",
     "125 ml melk",
     "1 eier geklits",
     "80 ml appelkooskonfyt",
     "60 ml asyn",
     "60 ml matige kerrie",
     "30 ml borrie",
     "1 appel gerasper (opsioneel)",
     "2 lourier of suurlemoenblare",
     "Amandelsplinters opsioneel"
    ]
   }
  ],
  "directionsTitle": "Metode",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Braai jou gesnyde ui in die olie tot glaserig.",
     "Laat die brood week in die melk en krummel dit in by jou vleis in jou mengbak – hou die melk vir jou bo-laag.",
     "Meng al die res van die bestandele in by die vleis behalwe die lourier/suurlemoenblare, amandels , eier en melk.",
     "Meng nou die gaar uie by jou vleis.",
     "Sit die mengsel in ‘n gesmeerde oondbak. Moet dit nie styf indruk nie.",
     "Meng nou jou eier en melk liggies met ‘n vurk en gooi oor die vleis.",
     "Druk jou suurlemoen/lourierblare in die vleis en sprinkel die amandels bo-oor.",
     "Bak vir 60 minut by 180C."
    ]
   }
  ],
