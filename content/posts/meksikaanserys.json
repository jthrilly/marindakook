   {
    "title": null,
    "items": [
     "250 ml Spekko langkorrel witrys",
     "2 chillies fyngekap ( jy kan meer insit as jy hou van sterkkos)",
     "2 knoffelhuisies fyngekap",
     "1 ui fyngekap",
     "20 ml fynkomyn",
     "50g tamatiepaste",
     "375 ml hoenderaftreksel ( los 1 blokkie op in 375ml kookwater)",
     "1 rooi soetpeper in blokkies gesny",
     "60 ml olie vir braai",
     "vars koriander vir bo-op sit"
    ]
   }
  ],
  "directionsTitle": "Metode",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Braai die uie vir 5 minute.  Voeg die knoffel, chillies, rooipeper en komyn by en braai vir nog 3 minute.",
     "Gooi die rys by en braai die rys vir 2 minute.",
     "Roer die tamatiespaste by die hoenderaftreksel en gooi dit oor die rys.  Roer dit deur.",
     "Sit die deksel op en laat die rys sagkook.  Roer gereeld en vul aan met water.",
     "As die rys gaar is, skep dit in ’n mooi bak en breek die koriander op dit."
    ]
   }
