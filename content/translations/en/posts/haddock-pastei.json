  "ingredientsTitle": "Ingredients",
  "ingredientGroups": [
   {
    "title": null,
    "items": [
     "1.2 kg haddock",
     "6 black peppercorns",
     "750 ml milk"
    ]
   },
   {
    "title": "Cheese sauce",
    "items": [
     "125 ml butter",
     "125 ml cake flour",
     "750 ml milk (use the milk you cooked the fish in. If it's too little, top it up)",
     "250 ml grated cheese",
     "2.5 ml mustard powder",
     "Salt and pepper to taste"
    ]
   },
   {
    "title": "Mashed potatoes",
    "items": [
     "5 large potatoes, cooked",
     "125 ml warm milk",
     "90 ml butter",
     "Salt and pepper",
     "Paprika, optional, to sprinkle on top"
    ]
   }
  ],
  "directionsTitle": "Method",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Cook the fish in the milk with the peppercorns until done.",
     "Take it out of the milk (keep the milk for your cheese sauce) and flake the fish. Discard the peppercorns.",
     "For the cheese sauce, melt the butter in a small pot.",
     "Stir in the flour with a whisk.",
     "Add the milk you kept from the fish and stir with the whisk until smooth. Let it simmer for 5 minutes.",
     "Taste and season with salt and pepper to taste.",
     "Stir in the cheese.",
     "Stir in the flaked fish and spoon into an oven dish.",
     "Make your mashed potatoes by stirring the butter and warm milk into the hot potatoes. Mash well with a masher.",
     "Season with salt and pepper to taste.",
     "Spoon over your fish in the oven dish and sprinkle paprika on top if you enjoy a bit of a kick.",
     "Bake for 30 minutes at 180 degrees Celsius."
    ]
   }
  ],
