  "ingredientGroups": [
   {
    "title": null,
    "items": [
     "600 g frozen mashed potato (from Woolies) or make your own",
     "butter (optional)",
     "1 roll puff pastry",
     "4 cooked pork sausages",
     "20 ml milk (if needed)",
     "salt and pepper to taste",
     "250 ml grated cheddar cheese"
    ]
   }
  ],
  "directionsTitle": "Method",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Prepare the frozen mashed potato as directed on the packet and season to taste with salt and pepper. If you feel like it, add as much butter as you like. Let it cool slightly.",
     "Unroll your pastry onto a greased baking tray.",
     "Spread a layer of mashed potato",
     "Arrange the sausages in a long row on the potato",
     "Spread more mashed potato",
     "Sprinkle the cheese over",
     "Now fold the pastry closed like a sausage",
     "Cut slits in the pastry",
     "Brush with milk or egg",
     "Bake for 40 minutes at 180C"
    ]
   }
