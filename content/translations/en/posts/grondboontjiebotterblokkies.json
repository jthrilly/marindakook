  "ingredientsTitle": "Ingredients",
  "ingredientGroups": [
   {
    "title": null,
    "items": [
     "400 g peanut butter (can be crunchy or smooth)",
     "2 x 150g Milkybar chocolate, broken into rough pieces",
     "120 g / 125 ml butter",
     "4 x 250 ml small pink and white marshmallows",
     "Extra marshmallows for sprinkling on top",
     "I also added Chuckles on top"
    ]
   }
  ],
  "directionsTitle": "Method",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Line a dish with baking paper and spray with Spray and Cook",
     "Melt the peanut butter, chocolate and butter in a pot on the stove or in the microwave. Let it cool slightly. Stir regularly with a wooden spoon.",
     "Stir the marshmallows into the peanut butter mixture.",
     "Scrape the mixture out onto the baking paper and smooth it down.  Sprinkle the remaining marshmallows and Chuckles over.  Press down lightly.",
     "Put it in the fridge overnight or for at least 2 hours.",
     "Cut into squares."
    ]
   }
  ],
  "notesTitle": "Notes",
  "notes": [
   "You can add cherries, nuts, dried fruit, etc.",
   "If you want to cut it easily, dip the tip of the knife in boiling water."
  ],
