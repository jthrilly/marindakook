  "ingredientsTitle": "Ingredients",
  "ingredientGroups": [
   {
    "title": null,
    "items": [
     "1 kg cake flour",
     "20 ml soft butter",
     "2 eggs",
     "1 packet yeast",
     "20 ml aniseed",
     "15 ml sugar",
     "10 ml honey",
     "750 ml lukewarm milk",
     "Salt",
     "Apricot jam to brush over crust"
    ]
   }
  ],
  "directionsTitle": "Method",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "In your mixer add the cake flour, aniseed, salt, sugar and soft butter. Mix lightly.",
     "In a jug mix the lukewarm milk, yeast, honey and eggs. Add this to the flour mixture and beat with your dough hook for 12 – 15 minutes.",
     "Scrape the slack dough out into a bowl greased with oil and let it rise until double in size. Set the oven to 180ºC.",
     "Line a baking tray with baking paper.",
     "Scrape the dough out onto a surface with a little oil on it. Divide it in two and shape your loaves on the baking tray. Let it stand for 20 minutes.",
     "Bake for 30 minutes. When it comes out, brush with apricot jam."
    ]
   }
  ],
