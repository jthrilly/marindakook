  "ingredientsTitle": "Ingredients",
  "ingredientGroups": [
   {
    "title": null,
    "items": [
     "8 chicken thighs",
     "1 red onion, sliced into rings",
     "1 tomato, sliced into rings",
     "Olive oil",
     "Salt",
     "Pepper",
     "500 ml Spekko Basmati rice (rinse and drain it)",
     "2 garlic cloves, finely grated",
     "4 x 250 ml boiling water",
     "5 ml paprika",
     "15 ml Baharat (buy it at Woolies)",
     "30 ml date syrup or honey (buy date syrup at Woolies too)",
     "50 ml tomato paste",
     "Chopped parsley to finish"
    ]
   }
  ],
  "directionsTitle": "Method",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Set the oven to 180°C",
     "Sprinkle 10 ml coarse salt on the bottom of your pan.",
     "Drizzle the pan with a thin layer of olive oil.",
     "Pack the sliced red onion and tomato on the olive oil.",
     "Spoon the drained rice onto the layer of tomato slices and onion.",
     "Pack the chicken on top of the rice. Salt and pepper to taste.",
     "Now for your sauce: mix the paprika, Baharat, date syrup, tomato paste, fine garlic and 125 ml olive oil together – it smells amazing.",
     "Now stir in your boiling water and mix well. Spoon it evenly over the chicken.",
     "Now: wet some baking paper and cover the chicken with the damp baking paper. Then cover with tinfoil so it can steam nicely.",
     "After 90 minutes, uncover and let the chicken brown in the oven.",
     "Finish off with chopped parsley.",
     "Utterly delicious!!!!!!!!!!"
    ]
   }
  ],
