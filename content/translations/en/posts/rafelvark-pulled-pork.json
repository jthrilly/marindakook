 "html": "<p>&nbsp;</p>\n<p>&nbsp;</p>\n<p><img loading=\"lazy\" class=\"aligncenter wp-image-5892 size-large\" src=\"/media/uploads/2020/06/RN8A9494-1024x809.jpg\" alt width=\"530\" height=\"419\" srcset=\"/media/uploads/2020/06/RN8A9494-1024x809.jpg 1024w, /media/uploads/2020/06/RN8A9494-600x474.jpg 600w, /media/uploads/2020/06/RN8A9494-300x237.jpg 300w, /media/uploads/2020/06/RN8A9494-768x606.jpg 768w, /media/uploads/2020/06/RN8A9494-1536x1213.jpg 1536w, /media/uploads/2020/06/RN8A9494-750x592.jpg 750w, /media/uploads/2020/06/RN8A9494-380x300.jpg 380w, /media/uploads/2020/06/RN8A9494-760x600.jpg 760w, /media/uploads/2020/06/RN8A9494-800x632.jpg 800w, /media/uploads/2020/06/RN8A9494-90x70.jpg 90w, /media/uploads/2020/06/RN8A9494.jpg 2048w\" sizes=\"auto, (max-width: 530px) 100vw, 530px\"></p>\n<p>&nbsp;</p>\n<p><strong><u>PULLED PORK IN THE PRESSURE COOKER</u></strong></p>\n<p><strong><u>INGREDIENTS</u></strong></p>\n<ul>\n<li>2 kg pork shoulder</li>\n<li>1 tin coke</li>\n<li>625 ml good-quality store-bought BBQ sauce</li>\n<li>100 ml brown sugar</li>\n<li>60 ml apple cider vinegar</li>\n<li>10 ml garlic powder</li>\n<li>5 ml salt powder</li>\n<li>15 ml smoked paprika</li>\n</ul>\n<p><strong><u>METHOD</u></strong></p>\n<ol>\n<li>Place the pork shoulder in the pressure cooker.</li>\n<li>Mix all the rest of the ingredients and pour over the pork shoulder.</li>\n<li>Cook for 90 minutes in the pressure cooker.</li>\n<li>Remove and shred.</li>\n</ol>\n<p><img loading=\"lazy\" class=\"aligncenter wp-image-5891 size-medium\" src=\"/media/uploads/2020/06/RN8A9482-300x200.jpg\" alt width=\"300\" height=\"200\" srcset=\"/media/uploads/2020/06/RN8A9482-300x200.jpg 300w, /media/uploads/2020/06/RN8A9482-600x400.jpg 600w, /media/uploads/2020/06/RN8A9482-1024x683.jpg 1024w, /media/uploads/2020/06/RN8A9482-768x512.jpg 768w, /media/uploads/2020/06/RN8A9482-1536x1024.jpg 1536w, /media/uploads/2020/06/RN8A9482-800x530.jpg 800w, /media/uploads/2020/06/RN8A9482-750x500.jpg 750w, /media/uploads/2020/06/RN8A9482-380x253.jpg 380w, /media/uploads/2020/06/RN8A9482-760x507.jpg 760w, /media/uploads/2020/06/RN8A9482-1600x1060.jpg 1600w, /media/uploads/2020/06/RN8A9482-900x600.jpg 900w, /media/uploads/2020/06/RN8A9482-1800x1200.jpg 1800w, /media/uploads/2020/06/RN8A9482.jpg 2048w\" sizes=\"auto, (max-width: 300px) 100vw, 300px\"></p>",
