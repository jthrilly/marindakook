  "ingredientsTitle": "Ingredients",
  "ingredientGroups": [
   {
    "title": null,
    "items": [
     "2 onions sliced into rings<br>1.5kg lamb",
     "30 ml oil",
     "5 cloves garlic crushed",
     "Thumb-sized piece of ginger, grated",
     "10 ml coriander",
     "10 ml cumin",
     "10 ml chilli flakes",
     "15 ml vinegar",
     "15 ml sugar",
     "15 ml apricot jam",
     "15 ml turmeric",
     "30 ml strong curry powder",
     "1 star anise",
     "3 cardamom pods, crushed",
     "1 tin tomato puree",
     "250 ml stock (1 stock cube dissolved in 250 ml boiling water)",
     "Salt and pepper",
     "3 potatoes cut into cubes"
    ]
   }
  ],
  "directionsTitle": "Method",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Fry the onion lightly in oil",
     "Now fry the garlic and ginger together with the onions",
     "Fry the curry powder, turmeric, cumin and coriander together with the onion.",
     "Add the meat and fry quickly to coat in the spices",
     "Mix the rest of the ingredients and add to the meat mixture",
     "Put the lid on and let it simmer for 45 minutes. Now taste to see if you want to add more chilli, sugar or vinegar.",
     "Now add the potatoes.",
     "Cook until the meat and potatoes are tender."
    ]
   }
