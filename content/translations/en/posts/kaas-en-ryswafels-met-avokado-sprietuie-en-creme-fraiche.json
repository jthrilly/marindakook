  "ingredientsTitle": "Ingredients",
  "ingredientGroups": [
   {
    "title": null,
    "items": [
     "¾ cup Spekko long-grain parboiled rice",
     "3 cups water",
     "2ml salt",
     "1 x tin whole-kernel corn",
     "½ cup grated cheddar cheese",
     "2 eggs"
    ]
   },
   {
    "title": "For the topping",
    "items": [
     "½ cup crème fraîche",
     "1 lemon",
     "salt",
     "ground black pepper",
     "2 spring onions",
     "1 avocado",
     "5ml chilli flakes",
     "fresh coriander"
    ]
   }
  ],
  "directionsTitle": "Method",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Bring the water, salt and Spekko rice to the boil in a pot",
     "Lower the heat to medium and cook for 20-25 minutes",
     "Pour the rice into a sieve to drain off the excess water",
     "Set it aside to cool",
     "Drain the whole-kernel corn and pat dry with kitchen paper or a clean cloth",
     "Mix the rice and grated cheese with ¾ of the whole-kernel corn in a mixing bowl (keep the rest for serving)",
     "Whisk the eggs and then mix them well into the rice mixture",
     "Heat a waffle pan and spray it with a cooking spray (\"Spray &amp; Cook\")",
     "Pour a spoonful of the mixture into the preheated waffle pan, close the lid, and cook until golden brown",
     "Make waffles with all of the batter",
     "While the waffles are cooking, you can start preparing the topping",
     "Mix the crème fraîche with finely grated lemon zest and a pinch of salt and pepper",
     "Slice the spring onions thinly",
     "Slice the avocado thinly and squeeze lemon juice over",
     "Place the waffles on a serving platter and top each waffle with a few slices of avocado and a spoonful of crème fraîche",
     "Then sprinkle the spring onions and the remaining whole-kernel corn over",
     "Garnish with chilli flakes and fresh coriander"
    ]
   }
