  "ingredientsTitle": "Ingredients",
  "ingredientGroups": [
   {
    "title": "Meatballs",
    "items": [
     "2 slices bread soaked in 250 ml milk",
     "1 kg minced beef",
     "1 egg",
     "5 ml ground nutmeg",
     "2,5 ml ground cloves",
     "2,5 ml ground ginger",
     "5 ml chilli powder",
     "salt and pepper to taste",
     "flour"
    ]
   },
   {
    "title": "Sauce",
    "items": [
     "3 medium onions, finely chopped",
     "15 ml cake flour",
     "90ml vinegar",
     "250 ml water",
     "20 ml curry powder",
     "10 ml turmeric",
     "40 ml apricot jam",
     "6 bananas, finely sliced",
     "15 ml sugar",
     "salt and pepper to taste",
     "coconut"
    ]
   }
  ],
  "directionsTitle": "Method",
  "directionGroups": [
   {
    "title": "Meatballs",
    "steps": [
     "Set the oven to 180ºC.",
     "Crumble the bread and mix the ingredients well with the meat.",
     "Grease an oven dish with butter.",
     "Shape the meatballs and roll them in the flour.",
     "Pack the meatballs into a dish."
    ]
   },
   {
    "title": "Sauce",
    "steps": [
     "Fry the onions light brown in oil.",
     "Stir in the flour.",
     "Slowly stir in the vinegar and water.",
     "Add the curry powder, turmeric, jam, sugar, salt, pepper and bananas.",
     "Let it cook for 5 minutes.",
     "Pour the sauce over the meatballs and sprinkle coconut on top.",
     "Bake at 180ºC for about 1 hour.",
     "Serve with yoghurt bread and Curried Onion Sambals"
    ]
   }
  ],
