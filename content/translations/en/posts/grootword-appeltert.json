   {
    "title": null,
    "items": [
     "411 g (1 tin) pie apples &#8211; drained",
     "2 eggs",
     "190 ml castor sugar",
     "5 ml vanilla essence",
     "85 ml milk",
     "60 ml butter, melted",
     "250 ml cake flour",
     "5 ml baking powder",
     "2 ml salt"
    ]
   },
   {
    "title": "Sauce",
    "items": [
     "1 small tin Ideal milk",
     "125 ml cream",
     "250 ml sugar",
     "5 ml vanilla essence"
    ]
   }
  ],
  "directionsTitle": "Method",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Whisk the eggs, castor sugar and vanilla together",
     "Whisk in the milk and then the melted butter.",
     "Sift the dry ingredients together and whisk it all into the egg mixture.",
     "Pour the batter into a greased tart pan and press the apples into the batter.",
     "Bake for 30 – 40 minutes at 180C",
     "Cook the Ideal milk, cream, sugar and vanilla essence together until the sugar has dissolved. Pour it over the tart the moment it comes out of the oven."
    ]
   }
