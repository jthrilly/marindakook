  "ingredientsTitle": "Ingredients",
  "ingredientGroups": [
   {
    "title": null,
    "items": [
     "6 potatoes<br><img src=\"/media/uploads/2017/10/aartappelslaai-001-300x225.jpg\" title=\"aartappelslaai-001\" alt class=\"direction-step-image\" loading=\"lazy\">",
     "1 onion, finely chopped",
     "1/2 cup parsley, finely chopped",
     "250 ml mayonnaise ( 1 cup)",
     "125 ml Greek yoghurt ( half cup)<br><img src=\"/media/uploads/2017/10/aartappelslaai-015-225x300.jpg\" title=\"aartappelslaai-015\" alt class=\"direction-step-image\" loading=\"lazy\">",
     "15 ml sugar",
     "60 ml milk",
     "60 ml mustard ( wholegrain mustard)",
     "2 hard-boiled eggs<br><img src=\"/media/uploads/2017/10/aartappelslaai-003-300x225.jpg\" title=\"aartappelslaai-003\" alt class=\"direction-step-image\" loading=\"lazy\">",
     "1 wheel of feta cheese<br><img src=\"/media/uploads/2017/10/aartappelslaai-024-300x225.jpg\" title=\"aartappelslaai-024\" alt class=\"direction-step-image\" loading=\"lazy\">",
     "salt and pepper"
    ]
   }
  ],
  "directionsTitle": "Method",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Boil the potatoes until soft and cut into cubes.",
     "Add the chopped onion.<img loading=\"lazy\" width=\"1500\" height=\"1125\" src=\"/media/uploads/2017/10/aartappelslaai-008.jpg\" class=\"direction-step-image\" alt title=\"aartappelslaai-008\">",
     "Add the chopped parsley.<img loading=\"lazy\" width=\"1500\" height=\"1125\" src=\"/media/uploads/2017/10/aartappelslaai-013.jpg\" class=\"direction-step-image\" alt title=\"aartappelslaai-013\">",
     "Mix the mayonnaise, yoghurt, milk, sugar, salt, pepper and mustard together and pour over the potatoes.<img loading=\"lazy\" width=\"1500\" height=\"1125\" src=\"/media/uploads/2017/10/aartappelslaai-018.jpg\" class=\"direction-step-image\" alt title=\"aartappelslaai-018\">",
     "Stir through gently without breaking up the potatoes.<img loading=\"lazy\" width=\"1500\" height=\"1125\" src=\"/media/uploads/2017/10/aartappelslaai-021.jpg\" class=\"direction-step-image\" alt title=\"aartappelslaai-021\">",
     "Grate the eggs over.<br><img loading=\"lazy\" width=\"1500\" height=\"1125\" src=\"/media/uploads/2017/10/aartappelslaai-022.jpg\" class=\"direction-step-image\" alt title=\"aartappelslaai-022\">",
     "Crumble the feta over.",
     "Sprinkle a bit more parsley over for some green. <img loading=\"lazy\" width=\"1500\" height=\"1125\" src=\"/media/uploads/2017/10/aartappelslaai-026.jpg\" class=\"direction-step-image\" alt title=\"aartappelslaai-026\">You can catch me out with potato salad any day.<br><img loading=\"lazy\" width=\"1500\" height=\"1125\" src=\"/media/uploads/2017/10/aartappelslaai-031.jpg\" class=\"direction-step-image\" alt title=\"aartappelslaai-031\">"
    ]
   }
