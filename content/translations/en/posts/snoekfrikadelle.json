  "ingredientsTitle": "Ingredients",
  "ingredientGroups": [
   {
    "title": null,
    "items": [
     "800g cooked snoek, flaked",
     "250 ml mash (about one large potato)",
     "1 lemon, juiced and finely grated zest",
     "250 ml finely chopped parsley (you can add more)",
     "1 packet brown onion soup powder",
     "1 onion, finely grated",
     "salt and white pepper to taste",
     "breadcrumbs to roll in"
    ]
   }
  ],
  "directionsTitle": "Method",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Mix the fish, onion, parsley, lemon juice, lemon zest, mash, soup powder and salt and pepper together in a bowl.",
     "Form balls and flatten them slightly with your hand. (I used a large ice cream scoop).",
     "Roll the cakes in the breadcrumbs and place them on a baking tray lined with baking paper in the fridge for 1 hour.",
     "Bake until golden brown in oil, in the oven or in the Airfryer. I like to fry mine in a pan with a shallow layer of oil on the stove. Drain on paper towel."
    ]
   }
  ],
