  "ingredientsTitle": "Ingredients",
  "ingredientGroups": [
   {
    "title": null,
    "items": [
     "Oil to fry the onion in",
     "1 onion, diced",
     "500 ml white wine",
     "250 ml water",
     "2 cloves",
     "2 sprigs each of rosemary and thyme",
     "4 chicken breasts or one whole chicken",
     "Salt and pepper",
     "300 g broccoli, broken into pieces",
     "1 packet mushroom soup powder",
     "500 ml milk",
     "Curry powder to taste",
     "250 ml mayonnaise",
     "40 ml lemon juice",
     "350 ml grated cheese"
    ]
   }
  ],
  "directionsTitle": "Method",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "In a large pot, heat the oil and fry the onion until glassy. Add the white wine, water, cloves, rosemary, thyme and chicken and season to taste with salt and pepper. Cook the chicken until tender.",
     "Take the chicken out of the pot, but keep the cooking liquid.",
     "Shred the chicken and remove the skin and bones. Place the shredded chicken in an ovenproof dish and set aside.",
     "Add the broccoli to the chicken stock and cook until just tender. Drain and place the broccoli on top of the shredded chicken.",
     "In a separate pot, mix the mushroom soup powder and milk and heat slowly until it starts to thicken. Add the curry powder, mayonnaise and lemon juice and cook for about 4 minutes. Remove from the heat and pour over the chicken and broccoli. Sprinkle the cheese over and bake in a preheated oven for 30 minutes at 180º C or until the cheese has melted and the chicken is hot. Easy!"
    ]
   }
  ],
  "notesTitle": "Notes",
  "notes": [
   "Serves 6 with oven-roasted vegetables."
