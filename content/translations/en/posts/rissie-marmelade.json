  "ingredientsTitle": "Ingredients",
  "ingredientGroups": [
   {
    "title": null,
    "items": [
     "200 gram sweet peppers (bell peppers, yellow, green, red. Any colour)",
     "150 gram chillies",
     "2 onions",
     "5 cloves garlic",
     "875 ml/3.5 cups sugar",
     "250 ml/1 cup vinegar",
     "10 ml mixed spice",
     "10 ml salt",
     "(400g) 1 tin tomato puree"
    ]
   }
  ],
  "directionsTitle": "Method",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Coarsely chop the sweet peppers, chillies, onions and garlic in your food processor.",
     "Now put all the ingredients into a pot and cook for 1 hour on medium heat. Stir regularly and watch that it doesn't catch on the bottom. Taste and adjust to your liking. The sauce turns dark and thick.",
     "Sterilise your jars. Pour the sauce into your jars."
    ]
   }
  ],
  "notesTitle": "Notes",
  "notes": [
   "Delicious with a cheese board, alongside meat, or on a boerewors roll.",
   "Tip: Taste the chillies raw. If they're very hot, scrape out the seeds or use fewer chillies.",
   "I chopped my vegetables finely, but not into a pulp."
  ],
