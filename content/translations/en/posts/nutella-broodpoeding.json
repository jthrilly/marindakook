  "directionsTitle": "Method",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Cut the croissants in half and spread them thickly with the Nutella.",
     "Layer the spread croissants like roof tiles, overlapping, in an ovenproof dish.",
     "Mix the cream, milk, eggs, vanilla essence and castor sugar well.",
     "Pour it over the croissants.",
     "Let it stand for 60 minutes.",
     "Then bake it for 40 minutes at 180 °C.",
     "Take it out of the oven and serve with custard or ice cream."
