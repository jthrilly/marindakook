  "ingredientsTitle": "Ingredients",
  "ingredientGroups": [
   {
    "title": null,
    "items": [
     "8 chicken breasts",
     "1 onion",
     "500 ml white wine",
     "250 ml water",
     "4 whole cloves",
     "a sprig of rosemary and thyme if you have them",
     "1 kg broccoli",
     "1 packet mushroom soup",
     "1 l milk",
     "500 ml mayonnaise",
     "80 ml curry powder",
     "80 ml lemon juice",
     "salt and pepper to taste",
     "oil to fry the onions in",
     "750 ml cheese<br><a rel aria-label href=\"/media/uploads/2017/10/broccoli-hoender-blog-025.jpg\" target=\"_blank\"><img src=\"/media/uploads/2017/10/broccoli-hoender-blog-025-1024x768.jpg\" title=\"Broccoli chicken - my kids' favourite\" alt=\"broccoli hoender blog 025\" class=\"direction-step-image\" loading=\"lazy\"></a>"
    ]
