  "ingredientsTitle": "Ingredients",
  "ingredientGroups": [
   {
    "title": null,
    "items": [
     "25 ml oil",
     "1 onion, finely chopped",
     "750g – 1kg good quality mince",
     "3 slices of bread",
     "125 ml milk",
     "1 egg, beaten",
     "80 ml apricot jam",
     "60 ml vinegar",
     "60 ml medium curry powder",
     "30 ml turmeric",
     "1 apple, grated (optional)",
     "2 bay or lemon leaves",
     "Flaked almonds, optional"
    ]
   }
  ],
  "directionsTitle": "Method",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Fry your chopped onion in the oil until glossy.",
     "Let the bread soak in the milk and crumble it into your meat in your mixing bowl – keep the milk for your top layer.",
     "Mix in all the rest of the ingredients with the meat except the bay/lemon leaves, almonds, egg and milk.",
     "Now mix the cooked onions into your meat.",
     "Put the mixture into a greased oven dish. Don't pack it in tightly.",
     "Now lightly whisk your egg and milk together with a fork and pour over the meat.",
     "Press the lemon/bay leaves into the meat and sprinkle the almonds on top.",
     "Bake for 60 minutes at 180C."
    ]
   }
  ],
