  "directionsTitle": "Method",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Boil the potatoes until soft and cut into cubes.",
     "Add the chopped onion on top.",
     "Sprinkle the chopped parsley over.",
     "Mix the mayonnaise, yoghurt, milk, sugar, salt, pepper and mustard together and pour it over the potatoes.",
     "Stir through gently without breaking up the potatoes.",
     "Grate the eggs over.",
     "Crumble the feta over.",
     "Sprinkle a bit more parsley over for some green."
