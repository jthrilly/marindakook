     "6 potatoes",
     "1 onion, finely chopped",
     "½ c parsley, finely chopped",
     "250 ml (1 c) mayonnaise",
     "125 ml (½ c) Greek yoghurt",
     "60 ml milk",
     "15 ml sugar",
     "salt and pepper",
     "60 ml mustard (wholegrain mustard)",
     "2 hard-boiled eggs",
     "1 wheel of feta cheese"
