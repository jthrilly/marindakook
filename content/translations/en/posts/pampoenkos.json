  "ingredientsTitle": "Ingredients",
  "ingredientGroups": [
   {
    "title": null,
    "items": [
     "500g beef mince",
     "1 x 690 g bottle of store-bought tomato pasta sauce of your choice",
     "750 ml cooked rice (3 cups)",
     "750 ml cooked pumpkin, mashed",
     "20 ml oil",
     "1 onion, finely chopped",
     "20 ml butter",
     "2,5 ml ground cinnamon",
     "salt and pepper"
    ]
   }
  ],
  "directionsTitle": "Method",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Set the oven to 180C and grease a square oven dish.",
     "Fry the onion lightly in the oil. Add your mince and fry until it starts to brown.",
     "Pour the pasta sauce over the mince and cook for 10-15 minutes until everything starts to thicken. Salt and pepper to taste. Set it aside until you need it.",
     "While the pumpkin is warm, stir in the cinnamon, butter and salt and pepper.",
     "Place your rice at the bottom of the oven dish.",
     "Spoon the pumpkin over the rice.",
     "Spoon the mince over the pumpkin.",
     "Bake in the oven for 25 minutes."
    ]
   }
  ],
