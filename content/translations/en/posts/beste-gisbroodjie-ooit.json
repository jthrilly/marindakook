  "ingredientGroups": [
   {
    "title": null,
    "items": [
     "750 ml cake flour",
     "5 ml salt",
     "5 ml sugar",
     "1 packet instant yeast",
     "375 ml lukewarm water"
    ]
   }
  ],
  "directionsTitle": "Method",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Set your oven to 180 C",
     "Mix all the dry ingredients together",
     "Stir the lukewarm water into the flour mixture with a wooden spoon. Don't mix too much. It's a slack dough",
     "Spray a small bread pan or grease it with butter. Scrape the dough out into your pan. Dip your hands in flour and smooth your dough out with your hands <img loading=\"lazy\" width=\"1280\" height=\"960\" src=\"/media/uploads/2025/06/Gisbrood-voor-bak.jpeg\" class=\"direction-step-image\" alt=\"Yeast bread before oven\" title=\"Yeast bread before baking\">",
     "Put the pan in a plastic bag and let it rise until double in size<img loading=\"lazy\" width=\"1280\" height=\"960\" src=\"/media/uploads/2025/06/Gisbrood-in-sak.jpeg\" class=\"direction-step-image\" alt title=\"Yeast bread in bag\">",
     "Bake for 30 min at 180 C <img loading=\"lazy\" width=\"1280\" height=\"960\" src=\"/media/uploads/2025/06/Gisbrood-heel.jpeg\" class=\"direction-step-image\" alt title=\"Yeast bread whole\">",
     "Spread butter over the crust<img loading=\"lazy\" width=\"1280\" height=\"960\" src=\"/media/uploads/2025/06/Gisbrood-botter.jpeg\" class=\"direction-step-image\" alt title=\"Yeast bread butter\">"
    ]
