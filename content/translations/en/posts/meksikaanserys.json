  "ingredientsTitle": "Ingredients",
  "ingredientGroups": [
   {
    "title": null,
    "items": [
     "250 ml Spekko long-grain white rice",
     "2 chillies finely chopped (you can add more if you like spicy food)",
     "2 garlic cloves finely chopped",
     "1 onion finely chopped",
     "20 ml ground cumin",
     "50g tomato paste",
     "375 ml chicken stock (dissolve 1 stock cube in 375ml boiling water)",
     "1 red pepper cut into blocks",
     "60 ml oil for frying",
     "fresh coriander for serving on top"
    ]
   }
  ],
  "directionsTitle": "Method",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Fry the onions for 5 minutes.  Add the garlic, chillies, red pepper and cumin and fry for another 3 minutes.",
     "Add the rice and fry the rice for 2 minutes.",
     "Stir the tomato paste into the chicken stock and pour it over the rice.  Stir it through.",
     "Put the lid on and let the rice simmer gently.  Stir regularly and top up with water.",
     "Once the rice is done, spoon it into a nice bowl and break the coriander over it."
    ]
   }
  ],
