  "ingredientsTitle": "Ingredients",
  "ingredientGroups": [
   {
    "title": null,
    "items": [
     "375 ml cake flour",
     "5 ml baking powder",
     "5 ml bicarbonate of soda",
     "2,5 ml salt",
     "2,5 ml ground cinnamon",
     "150 g white sugar",
     "3 bananas mashed",
     "1 egg lightly beaten",
     "5 ml vanilla essence",
     "76g butter melted",
     "80 g brown sugar",
     "30 ml cake flour",
     "pinch ground cinnamon",
     "15 ml cold butter"
    ]
   }
  ],
  "directionsTitle": "Method",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Set your oven to 180C. I mixed everything with just a fork throughout.",
     "Mix the white sugar, cake flour, baking powder, bicarbonate of soda, salt and 2,5 ml cinnamon in a bowl.",
     "In another bowl mix the egg, vanilla essence, melted butter and mashed banana. Add it to your dry ingredients and mix well.",
     "Spoon into a greased muffin tin. (I used paper cups)",
     "Mix the brown sugar, cake flour, pinch of ground cinnamon and butter with your hands until it looks like wet sand. Divide the crumble between your muffins.",
     "Bake for 20 to 25 min. Let it cool in the tin."
    ]
   }
  ],
