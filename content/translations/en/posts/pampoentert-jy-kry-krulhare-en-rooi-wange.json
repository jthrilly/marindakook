  "ingredientsTitle": "Ingredients",
  "ingredientGroups": [
   {
    "title": null,
    "items": [
     "750 ml cooked pumpkin (3 cups)",
     "1 tin ideal milk or 150 ml milk and 150 ml cream",
     "3 eggs",
     "15 ml baking powder (3 teaspoons)",
     "250 ml cake flour (1 cup)",
     "250 ml sugar (1 cup)",
     "pinch of salt",
     "cinnamon sugar"
    ]
   }
  ],
  "directionsTitle": "Method",
  "directionGroups": [
   {
    "title": null,
    "steps": [
     "Cook your pumpkin with a cinnamon stick until soft.<img loading=\"lazy\" width=\"1500\" height=\"1125\" src=\"/media/uploads/2017/10/broccoli-hoender-blog-073.jpg\" class=\"direction-step-image\" alt title=\"broccoli-hoender-blog-073\">",
     "Drain it and mash it smooth.<img loading=\"lazy\" width=\"1500\" height=\"1125\" src=\"/media/uploads/2017/10/broccoli-hoender-blog-094.jpg\" class=\"direction-step-image\" alt title=\"broccoli-hoender-blog-094\">",
     "Put the eggs, ideal milk, flour, sugar, baking powder and salt in a mixing bowl and whisk well.<img loading=\"lazy\" width=\"1500\" height=\"1125\" src=\"/media/uploads/2017/10/broccoli-hoender-blog-090.jpg\" class=\"direction-step-image\" alt title=\"broccoli-hoender-blog-090\">",
     "Add the pumpkin to the mixture and stir well.<img loading=\"lazy\" width=\"1500\" height=\"1125\" src=\"/media/uploads/2017/10/broccoli-hoender-blog-101.jpg\" class=\"direction-step-image\" alt title=\"broccoli-hoender-blog-101\">",
     "Spray or grease an oven dish and pour the loose pumpkin mixture into the oven dish.<img loading=\"lazy\" width=\"1500\" height=\"1125\" src=\"/media/uploads/2017/10/broccoli-hoender-blog-109.jpg\" class=\"direction-step-image\" alt title=\"broccoli-hoender-blog-109\">",
     "Bake for 60 minutes at 180 degrees celsius.<img loading=\"lazy\" width=\"1500\" height=\"1125\" src=\"/media/uploads/2017/10/pampoentert-vir-blog-003.jpg\" class=\"direction-step-image\" alt title=\"pampoentert-vir-blog-003\">",
     "Sprinkle cinnamon sugar over (125 ml white sugar and 10 ml ground cinnamon mixed).<img loading=\"lazy\" width=\"1500\" height=\"1125\" src=\"/media/uploads/2017/10/pampoentert-vir-blog-004.jpg\" class=\"direction-step-image\" alt title=\"pampoentert-vir-blog-004\">"
    ]
   }
  ],
  "notesTitle": "Notes",
  "notes": [
   "Now your gut will just have to decide for itself whether this is a vegetable or a pudding."
